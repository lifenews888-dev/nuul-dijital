generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===================== AUTH =====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  password      String?
  image         String?
  emailVerified DateTime?
  role          UserRole  @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  domains       Domain[]
  subscriptions Subscription[]
  orders        Order[]
  chatbots        ChatBot[]
  crmLeads        CRMLead[]
  tickets         Ticket[]
  hostingAccounts HostingAccount[]
  chatMessages    ChatMessage[]
  emailLists       EmailList[]
  emailCampaigns   EmailCampaign[]
  websites         Website[]
  notifications    Notification[]
  resellerProfile  ResellerProfile?
  referredBy       ResellerClient[]  @relation("ReferredClient")
  serviceQuotes    ServiceQuote[]
  blogPosts        BlogPost[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ===================== DOMAINS =====================

model Domain {
  id        String       @id @default(cuid())
  name      String       @unique
  tld       String
  userId    String?
  status    DomainStatus @default(PENDING)
  price     Int          // MNT
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user  User?  @relation(fields: [userId], references: [id])
  order Order? @relation("DomainOrder")

  @@index([userId])
  @@map("domains")
}

// ===================== HOSTING =====================

model HostingPlan {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  type        PlanType
  description String?
  price       Int         // MNT/сар
  priceYearly Int?        // MNT/жил
  storage     Int         // GB
  bandwidth   Int         // GB/сар, 0 = unlimited
  websites    Int
  emails      Int
  features    String[]
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  subscriptions Subscription[]

  @@map("hosting_plans")
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  startAt   DateTime           @default(now())
  endAt     DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  plan  HostingPlan @relation(fields: [planId], references: [id])
  order Order?      @relation("SubscriptionOrder")

  @@index([userId])
  @@map("subscriptions")
}

// ===================== ORDERS & PAYMENTS =====================

model Order {
  id             String      @id @default(cuid())
  userId         String
  domainId       String?     @unique
  subscriptionId String?     @unique
  type           OrderType
  amount         Int         // MNT
  status         OrderStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  domain       Domain?       @relation("DomainOrder", fields: [domainId], references: [id])
  subscription Subscription? @relation("SubscriptionOrder", fields: [subscriptionId], references: [id])
  payment      Payment?

  @@index([userId])
  @@map("orders")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  method        PaymentMethod
  transactionId String?
  amount        Int           // MNT
  status        PaymentStatus @default(PENDING)
  qpayInvoiceId String?
  qpayQrCode    String?       @db.Text
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ===================== AI CHATBOT =====================

model ChatBot {
  id        String          @id @default(cuid())
  userId    String
  name      String
  platform  ChatBotPlatform
  flowJson  String          @db.Text // JSON flow definition
  isActive  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("chatbots")
}

// ===================== CRM =====================

model CRMLead {
  id        String    @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  company   String?
  stage     LeadStage @default(NEW)
  value     Int?      // MNT
  notes     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("crm_leads")
}

// ===================== SUPPORT =====================

model Ticket {
  id         String       @id @default(cuid())
  userId     String
  subject    String
  message    String       @db.Text
  status     TicketStatus @default(OPEN)
  priority   Priority     @default(MEDIUM)
  aiResolved Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("tickets")
}

// ===================== HOSTING =====================

model HostingAccount {
  id        String        @id @default(cuid())
  userId    String
  serverId  Int           // Hetzner server ID
  serverIp  String?
  status    HostingStatus @default(PROVISIONING)
  planType  PlanType
  domain    String?
  expiresAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("hosting_accounts")
}

// ===================== CHAT MESSAGES =====================

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String?
  ticketId  String?
  role      String   // 'user' | 'assistant'
  content   String   @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([ticketId])
  @@map("chat_messages")
}

model ChatBotSession {
  id        String   @id @default(cuid())
  botId     String
  visitorId String
  messages  Json     // array of {role, content}
  createdAt DateTime @default(now())

  @@index([botId])
  @@map("chatbot_sessions")
}

// ===================== EMAIL MARKETING =====================

model EmailList {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  name        String
  description String?
  subscribers EmailSubscriber[]
  campaigns   EmailCampaign[]
  createdAt   DateTime          @default(now())

  @@index([userId])
  @@map("email_lists")
}

model EmailSubscriber {
  id             String    @id @default(cuid())
  listId         String
  list           EmailList @relation(fields: [listId], references: [id], onDelete: Cascade)
  email          String
  name           String?
  status         SubStatus @default(ACTIVE)
  tags           String[]
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@unique([listId, email])
  @@index([listId])
  @@map("email_subscribers")
}

model EmailCampaign {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  listId      String?
  list        EmailList?     @relation(fields: [listId], references: [id])
  name        String
  subject     String
  previewText String?
  htmlContent String         @db.Text
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  totalSent   Int            @default(0)
  delivered   Int            @default(0)
  opened      Int            @default(0)
  clicked     Int            @default(0)
  bounced     Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@map("email_campaigns")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  category    String
  htmlContent String   @db.Text
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("email_templates")
}

// ===================== WEBSITE BUILDER =====================

model Website {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  name          String
  domain        String?
  subdomain     String?       @unique
  template      String        @default("blank")
  gjsData       Json?
  publishedHtml String?       @db.Text
  status        WebsiteStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@map("websites")
}

// ===================== RESELLER =====================

model ResellerProfile {
  id             String             @id @default(cuid())
  userId         String             @unique
  user           User               @relation(fields: [userId], references: [id])
  companyName    String
  commissionRate Float              @default(0.20)
  totalEarned    Float              @default(0)
  balance        Float              @default(0)
  status         ResellerStatus     @default(PENDING)
  clients        ResellerClient[]
  withdrawals    ResellerWithdrawal[]
  createdAt      DateTime           @default(now())

  @@map("reseller_profiles")
}

model ResellerClient {
  id         String          @id @default(cuid())
  resellerId String
  reseller   ResellerProfile @relation(fields: [resellerId], references: [id])
  clientId   String
  client     User            @relation("ReferredClient", fields: [clientId], references: [id])
  createdAt  DateTime        @default(now())

  @@unique([resellerId, clientId])
  @@map("reseller_clients")
}

model ResellerWithdrawal {
  id          String           @id @default(cuid())
  resellerId  String
  reseller    ResellerProfile  @relation(fields: [resellerId], references: [id])
  amount      Float
  bankName    String
  accountNo   String
  status      WithdrawalStatus @default(PENDING)
  processedAt DateTime?
  createdAt   DateTime         @default(now())

  @@map("reseller_withdrawals")
}

// ===================== NOTIFICATIONS =====================

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      NotifType
  title     String
  message   String
  link      String?
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("notifications")
}

// ===================== NAVIGATION =====================

model NavItem {
  id        String   @id @default(cuid())
  label     String
  labelEn   String?
  href      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  openInNew Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nav_items")
}

// ===================== SERVICES =====================

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  services    Service[]
  createdAt   DateTime  @default(now())

  @@map("service_categories")
}

model Service {
  id           String          @id @default(cuid())
  categoryId   String
  category     ServiceCategory @relation(fields: [categoryId], references: [id])
  name         String
  description  String          @db.Text
  features     String[]
  price        Float?
  priceFrom    Float?
  priceTo      Float?
  priceLabel   String?
  deliveryDays Int?
  isActive     Boolean         @default(true)
  isFeatured   Boolean         @default(false)
  isComingSoon Boolean         @default(false)
  order        Int             @default(0)
  quotes       ServiceQuote[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([categoryId])
  @@map("services")
}

model ServiceQuote {
  id            String      @id @default(cuid())
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  name          String
  email         String
  phone         String
  company       String?
  projectType   String
  description   String      @db.Text
  budget        String?
  deadline      String?
  requirements  Json?
  status        QuoteStatus @default(PENDING)
  proposalDoc   String?     @db.Text
  contractDoc   String?     @db.Text
  agreedPrice   Float?
  isPaid        Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([serviceId])
  @@map("service_quotes")
}

// ===================== BLOG =====================

model BlogPost {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  content     String        @db.Text
  coverImage  String?
  videoUrl    String?
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  categoryId  String?
  category    BlogCategory? @relation(fields: [categoryId], references: [id])
  tags        String[]
  status      PostStatus    @default(DRAFT)
  featured    Boolean       @default(false)
  viewCount   Int           @default(0)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([authorId])
  @@map("blog_posts")
}

model BlogCategory {
  id    String     @id @default(cuid())
  name  String
  slug  String     @unique
  color String?
  posts BlogPost[]

  @@map("blog_categories")
}

// ===================== TESTIMONIALS =====================

model Testimonial {
  id        String   @id @default(cuid())
  text      String   @db.Text
  name      String
  role      String
  avatar    String   @default("")
  color     String   @default("violet")
  rating    Int      @default(5)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

// ===================== PORTFOLIO =====================

model Portfolio {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String   @db.Text
  coverImage  String?  // Vercel Blob URL — screenshot/thumbnail
  link        String?  // external (https://...) or internal (/path)
  status      String   @default("LIVE") // "LIVE" | "SOON" | "DRAFT"
  gradient    String   @default("from-[#7B6FFF]/30 via-[#7B6FFF]/10 to-transparent") // fallback tailwind classes when coverImage is empty
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("portfolios")
}

// ===================== MARKETING PLANS =====================

model MarketingPlan {
  id          String   @id @default(cuid())
  name        String
  price       String
  priceSmall  Boolean  @default(false)
  description String
  features    String[]
  featured    Boolean  @default(false)
  btnText     String   @default("Санал авах")
  btnLink     String   @default("/contact")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("marketing_plans")
}

// ===================== SITE SETTINGS =====================

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String
  group     String
  label     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ===================== ENUMS =====================

enum QuoteStatus {
  PENDING
  REVIEWING
  QUOTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WebsiteStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum ResellerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  PAID
  REJECTED
}

enum NotifType {
  PAYMENT_SUCCESS
  DOMAIN_EXPIRY
  HOSTING_READY
  SUPPORT_REPLY
  COMMISSION_EARNED
  SYSTEM
}

enum SubStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

enum UserRole {
  ADMIN
  CLIENT
  RESELLER
}

enum DomainStatus {
  AVAILABLE
  PENDING
  ACTIVE
  EXPIRED
  TRANSFERRING
}

enum PlanType {
  STARTER
  BUSINESS
  ENTERPRISE
  VPS_BASIC
  VPS_PRO
  VPS_CLOUD
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum OrderType {
  DOMAIN
  HOSTING
  CHATBOT
  CRM
  DOMAIN_AND_HOSTING
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  QPAY
  SOCIALPAY
  CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ChatBotPlatform {
  FACEBOOK
  WEB
  VIBER
  TELEGRAM
}

enum LeadStage {
  NEW
  CONTACTED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum HostingStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  DELETED
}
