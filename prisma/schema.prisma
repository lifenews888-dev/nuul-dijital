// Nuul Digital — Enterprise CMS schema (PostgreSQL)
// Run: npx prisma generate && npx prisma db push && npm run db:seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
//  Auth & RBAC
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  AUTHOR
  USER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // optional: DB-backed credentials
  role          Role      @default(USER)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  posts      Post[]
  pages      Page[]
  projects   Project[]
  caseStudies CaseStudy[]
  media      MediaAsset[]
  revisions        ContentRevision[]
  activity         ActivityLog[]
  domainOrders        DomainOrder[]
  fulfilledDomains    DomainOrder[]  @relation("DomainFulfilledBy")
  serviceOrders       ServiceOrder[]
  provisionedServices ServiceOrder[] @relation("ServiceProvisionedBy")
  ownedOrganizations  Organization[] @relation("OrgOwner")
  orgMemberships      OrgMember[]
}

enum OrgType {
  INDIVIDUAL
  BUSINESS
  RESELLER
  PARTNER
}

enum OrgRole {
  OWNER
  ADMIN
  BILLING
  TECH
  VIEWER
}

model Organization {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  type         OrgType  @default(INDIVIDUAL)
  billingEmail String
  ownerId      String
  owner        User     @relation("OrgOwner", fields: [ownerId], references: [id])
  members      OrgMember[]
  domainOrders DomainOrder[]
  serviceOrders ServiceOrder[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([billingEmail])
  @@index([ownerId])
}

model OrgMember {
  id        String       @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole      @default(VIEWER)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([orgId, userId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
//  Content workflow shared enum
// ============================================================

enum ContentStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

// ============================================================
//  Content models (with status workflow + embedded SEO)
//  SEO columns: seoTitle, seoDescription, seoKeywords[], ogImage, canonicalUrl
// ============================================================

model Page {
  id        String        @id @default(cuid())
  slug      String        @unique
  title     String
  content   String        @db.Text
  status    ContentStatus @default(DRAFT)
  publishedAt DateTime?
  scheduledAt DateTime?
  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]
  ogImage        String?
  canonicalUrl   String?
  authorId  String?
  author    User?         @relation(fields: [authorId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Post {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  excerpt     String        @db.Text
  content     String        @db.Text
  category    String
  cover       String
  tags        String[]
  featured    Boolean       @default(false)
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  scheduledAt DateTime?
  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]
  ogImage        String?
  canonicalUrl   String?
  authorId    String?
  author      User?         @relation(fields: [authorId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, publishedAt])
}

model Project {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  industry     String
  description  String        @db.Text
  technologies String[]
  results      Json
  image        String
  gallery      String[]
  link         String?
  year         String
  services     String[]
  featured     Boolean       @default(false)
  status       ContentStatus @default(DRAFT)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]
  ogImage        String?
  canonicalUrl   String?
  authorId     String?
  author       User?         @relation(fields: [authorId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model CaseStudy {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  client      String
  industry    String
  excerpt     String        @db.Text
  cover       String
  duration    String
  services    String[]
  challenge   String        @db.Text
  approach    String[]
  solution    String        @db.Text
  results     Json
  testimonial Json?
  featured    Boolean       @default(false)
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  scheduledAt DateTime?
  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]
  ogImage        String?
  canonicalUrl   String?
  authorId    String?
  author      User?         @relation(fields: [authorId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  quote     String   @db.Text
  author    String
  role      String
  company   String
  rating    Int      @default(5)
  avatar    String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String?  @db.Text
  avatar    String
  socials   Json? // { linkedin, twitter, github, ... }
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  category  String   @default("Ерөнхий")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  department       String
  location         String
  type             String
  level            String
  summary          String        @db.Text
  responsibilities String[]
  requirements     String[]
  status           ContentStatus @default(PUBLISHED)
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  applications     JobApplication[]
}

model JobApplication {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  resumeUrl String?
  message   String?  @db.Text
  createdAt DateTime @default(now())
}

// ============================================================
//  Media Library
// ============================================================

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

model MediaAsset {
  id           String    @id @default(cuid())
  url          String
  type         MediaType @default(IMAGE)
  filename     String
  mimeType     String?
  size         Int? // bytes
  width        Int?
  height       Int?
  alt          String?
  uploadedById String?
  uploadedBy   User?     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime  @default(now())

  @@index([type])
}

// ============================================================
//  Version History / Content Revisions
// ============================================================

model ContentRevision {
  id          String   @id @default(cuid())
  entity      String // "Post" | "Project" | "CaseStudy" | "Page"
  entityId    String
  version     Int
  data        Json // full snapshot of the record at save time
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  authorEmail String?
  createdAt   DateTime @default(now())

  @@unique([entity, entityId, version])
  @@index([entity, entityId])
}

// ============================================================
//  Activity Logs (audit trail)
// ============================================================

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  ARCHIVE
  RESTORE
  LOGIN
}

model ActivityLog {
  id        String         @id @default(cuid())
  userId    String?
  user      User?          @relation(fields: [userId], references: [id])
  userEmail String?
  action    ActivityAction
  entity    String // "Post", "Lead", "Media", ...
  entityId  String?
  summary   String
  metadata  Json?
  createdAt DateTime       @default(now())

  @@index([entity, createdAt])
  @@index([createdAt])
}

// ============================================================
//  Leads / CRM
// ============================================================

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  services  String[]
  budget    String?
  timeline  String?
  details   String?    @db.Text
  status       LeadStatus    @default(NEW)
  createdAt    DateTime      @default(now())
  domainOrders  DomainOrder[]
  serviceOrders ServiceOrder[]
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum MeetingStatus {
  REQUESTED
  SCHEDULED
  DONE
  CANCELLED
}

model Meeting {
  id          String        @id @default(cuid())
  name        String
  email       String
  phone       String?
  company     String?
  preferredAt String
  topic       String?
  message     String?       @db.Text
  status      MeetingStatus @default(REQUESTED)
  createdAt   DateTime      @default(now())
}

// Editable site settings (key/value) — e.g. logoUrl
model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// Detailed project intake brief (website / app / system request)
model ProjectBrief {
  id           String     @id @default(cuid())
  // Basics
  name         String // contact / project name
  phone        String
  email        String
  company      String?
  location     String?
  social       String?
  services     String[] // selected service pillars
  projectTypes String[] // Website, E-commerce, Mobile app, System, AI chatbot
  // Technical
  domainStatus String? // HAVE | BUY | SUGGEST
  domainName   String?
  hosting      Boolean?
  hasLogo      Boolean?
  // Business & content
  about        String     @db.Text
  goal         String     @db.Text
  audience     String?
  colors       String?
  pages        String[] // requested pages/sections (presets + custom)
  features     String[] // requested features (presets + custom)
  needsAuth    Boolean?
  references   String[] // reference site links
  timeline     String?
  budget       String?
  notes        String?    @db.Text
  status       LeadStatus @default(NEW)
  // Quote / estimate workflow
  estimateMin  Int? // auto-computed approximate range (₮)
  estimateMax  Int?
  finalQuote   Int? // admin-approved final amount (₮)
  quoteNote    String?    @db.Text
  meetingAt    String? // scheduled meeting date/time
  quoteSentAt  DateTime? // when the final quote was emailed to the client
  createdAt    DateTime   @default(now())
  domainOrders DomainOrder[]
}

// ============================================================
//  Domains & Growth Funnel
// ============================================================

enum TldStatus {
  ACTIVE
  DISABLED
}

model TldProduct {
  id            String    @id @default(cuid())
  tld           String    @unique
  labelMn       String
  labelEn       String
  registerPrice Int
  renewPrice    Int
  transferPrice Int?
  minYears      Int       @default(1)
  maxYears      Int       @default(5)
  featured      Boolean   @default(false)
  sortOrder     Int       @default(0)
  status        TldStatus @default(ACTIVE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders DomainOrder[]
}

model DomainSearch {
  id          String   @id @default(cuid())
  query       String
  ipHash      String?
  userAgent   String?
  resultCount Int
  results     Json
  latencyMs   Int?
  cached      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([query])
}

enum DomainOrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  FULFILLING
  COMPLETED
  CANCELLED
  REFUNDED
  EXPIRED
}

enum PaymentMethod {
  QPAY
  BANK_TRANSFER
  MANUAL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
  REFUNDED
}

model DomainOrder {
  id              String            @id @default(cuid())
  orderNumber     String            @unique
  domainName      String
  domainLabel     String
  tldProductId    String
  tldProduct      TldProduct        @relation(fields: [tldProductId], references: [id])
  years           Int               @default(1)
  unitPrice       Int
  totalAmount     Int
  currency        String            @default("MNT")
  status          DomainOrderStatus @default(PENDING_PAYMENT)

  customerName       String
  customerEmail      String
  customerPhone      String
  company            String?
  registrantType     String            @default("INDIVIDUAL")
  registrantAddress  String
  registrantIdType   String?
  registrantIdNumber String?
  businessRegNumber  String?
  registrantVerified Boolean           @default(false)

  userId         String?
  user           User?              @relation(fields: [userId], references: [id])
  orgId          String?
  organization   Organization?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  leadId         String?
  lead           Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  projectBriefId String?
  projectBrief   ProjectBrief?      @relation(fields: [projectBriefId], references: [id], onDelete: SetNull)
  journeyId      String?
  journey        OnboardingJourney? @relation(fields: [journeyId], references: [id], onDelete: SetNull)

  registrarName    String?
  registrarOrderId String?
  fulfilledAt      DateTime?
  fulfilledById    String?
  fulfilledBy      User?             @relation("DomainFulfilledBy", fields: [fulfilledById], references: [id])
  adminNotes       String?           @db.Text
  domainExpiresAt  DateTime?

  payment   Payment?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([customerEmail])
  @@index([domainName])
  @@index([orgId])
}

model Payment {
  id             String        @id @default(cuid())
  domainOrderId  String?       @unique
  domainOrder    DomainOrder?  @relation(fields: [domainOrderId], references: [id], onDelete: Cascade)
  serviceOrderId String?       @unique
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  method         PaymentMethod
  amount        Int
  status        PaymentStatus @default(PENDING)
  qpayInvoiceId String?
  qpayQrImage   String?       @db.Text
  qpayShortUrl  String?
  transactionId String?
  paidAt        DateTime?
  expiresAt     DateTime?
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([qpayInvoiceId])
}

enum JourneyStep {
  DOMAIN_SEARCH
  DOMAIN_PURCHASED
  HOSTING_SELECTED
  EMAIL_CONFIGURED
  WEBSITE_BRIEF
  LOGO_GENERATED
  SEO_SETUP
  MAPS_LISTED
  SOCIAL_CONNECTED
  CHATBOT_LIVE
  COMPLETED
}

enum JourneyStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

model OnboardingJourney {
  id             String         @id @default(cuid())
  sessionKey     String         @unique
  email          String?
  phone          String?
  businessName   String?
  businessNameMn String?
  currentStep    JourneyStep    @default(DOMAIN_SEARCH)
  status         JourneyStatus  @default(ACTIVE)
  selectedDomain String?
  metadata       Json?
  domainOrders   DomainOrder[]
  serviceOrders  ServiceOrder[]
  suggestionRuns DomainSuggestionRun[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([email])
  @@index([status, updatedAt])
}

enum ServiceType {
  HOSTING
  EMAIL
}

model ServiceOrder {
  id            String            @id @default(cuid())
  orderNumber   String            @unique
  serviceType   ServiceType
  planKey       String
  domainName    String?
  unitPrice     Int
  totalAmount   Int
  billingMonths Int               @default(1)
  currency      String            @default("MNT")
  status        DomainOrderStatus @default(PENDING_PAYMENT)

  customerName  String
  customerEmail String
  customerPhone String
  company       String?

  userId    String?
  user      User?              @relation(fields: [userId], references: [id])
  orgId     String?
  organization Organization?     @relation(fields: [orgId], references: [id], onDelete: SetNull)
  leadId    String?
  lead      Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  journeyId String?
  journey   OnboardingJourney? @relation(fields: [journeyId], references: [id], onDelete: SetNull)

  provisionedAt     DateTime?
  provisionedById   String?
  provisionedBy     User?   @relation("ServiceProvisionedBy", fields: [provisionedById], references: [id])
  adminNotes        String? @db.Text
  provisionDetails  Json?

  payment   Payment?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([customerEmail])
  @@index([serviceType])
  @@index([domainName])
  @@index([orgId])
}

model ServiceBundle {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameMn      String
  nameEn      String
  description String   @db.Text
  items       Json
  priceMnt    Int
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DomainSuggestionRun {
  id          String             @id @default(cuid())
  inputText   String
  inputLocale String             @default("mn")
  candidates  Json
  checked     Json?
  model       String?
  tokenUsage  Int?
  ipHash      String?
  journeyId   String?
  journey     OnboardingJourney? @relation(fields: [journeyId], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())

  @@index([createdAt])
  @@index([inputText, inputLocale])
}

// AI assistant chat history (per visitor session)
model ChatSession {
  id           String        @id // client-generated id
  email        String? // captured if the visitor shares one
  phone        String?
  userAgent    String?
  messageCount Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     ChatMessage[]

  @@index([updatedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // "user" | "assistant"
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

// ============================================================
//  Editable homepage / site content (was static src/data/company.ts)
// ============================================================

// Headline metrics shown on the hero / about (e.g. "120+ projects").
model Stat {
  id        String   @id @default(cuid())
  value     Int
  suffix    String   @default("")
  label     String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// "Why Nuul" differentiators / company values.
model Value {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// The how-we-work process steps (icon stored as a Lucide icon name).
model ProcessStep {
  id          String   @id @default(cuid())
  step        String // "01", "02", ...
  title       String
  description String   @db.Text
  icon        String   @default("Sparkles") // Lucide icon name
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
