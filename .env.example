# ---------- Database (PostgreSQL) ----------
DATABASE_URL="postgresql://user:password@localhost:5432/nuul?schema=public"

# ---------- Auth (Auth.js / NextAuth v5) ----------
# Generate with: npx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
# Admin login credentials (Credentials provider)
ADMIN_EMAIL="admin@nuul.digital"
ADMIN_PASSWORD="change-me-strong-password"

# ---------- Email (Resend) ----------
RESEND_API_KEY=""
CONTACT_TO_EMAIL="hello@nuul.digital"
CONTACT_FROM_EMAIL="Nuul Digital <noreply@nuul.digital>"

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"   # prod: https://nuul.digital

# ---------- Analytics (optional) ----------
NEXT_PUBLIC_GA_ID=""                  # e.g. G-XXXXXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""       # e.g. nuul.digital

# ---------- AI assistant (optional) ----------
# Set ONE provider to power the site chat with a real LLM. Without a key it
# falls back to a built-in knowledge-based assistant.
ANTHROPIC_API_KEY=""                  # uses Claude
ANTHROPIC_MODEL="claude-haiku-4-5"
OPENAI_API_KEY=""                     # alternative — uses OpenAI
OPENAI_MODEL="gpt-4o-mini"

# ---------- Vercel import (optional) ----------
# Powers the "Import from Vercel" button in /admin/projects (and the daily cron
# at /api/cron/import-vercel) which pull your Vercel projects in as DRAFT
# portfolio items. Create a token at vercel.com → Account Settings → Tokens.
# VERCEL_TEAM_ID is your team/org id. CRON_SECRET protects the cron endpoint
# (Vercel sends it as a Bearer token on scheduled runs).
VERCEL_API_TOKEN=""
VERCEL_TEAM_ID=""
CRON_SECRET=""

# ---------- Domains module (Phase 1+) ----------
# Feature flags are also stored in SiteSetting (seeded); env overrides optional.
# DOMAINS_MODULE_ENABLED="true"   # bypass DB flag for local /domains testing
# DOMAINS_SERVICE_ORDERS_ENABLED="true"   # bypass DB flag for local hosting/email checkout

# Registrar (Phase 6 scaffolding) — manual | reseller
# DOMAINS_REGISTRAR_PROVIDER="manual"
# DOMAINS_RESELLER_API_URL=""
# DOMAINS_RESELLER_API_KEY=""
# DOMAINS_RESELLER_STUB_SUCCESS="true"   # dev only: simulate reseller submit

# QPay (Mongolia) — required for online domain checkout (PR 9)
QPAY_USERNAME=""
QPAY_PASSWORD=""
QPAY_INVOICE_CODE=""
QPAY_ENV="sandbox"                    # sandbox | production
QPAY_CALLBACK_URL=""                  # prod: https://nuul.digital/api/payments/qpay/callback

# Upstash Redis — REQUIRED for production GA (shared rate limits across serverless)
# Create at https://console.upstash.com/ → copy REST URL + token
# Verify: curl http://localhost:3000/api/health/rate-limit
#         npm run verify:domains-deploy
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
