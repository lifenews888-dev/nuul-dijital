# ---------- Database (PostgreSQL) ----------
DATABASE_URL="postgresql://user:password@localhost:5432/nuul?schema=public"

# ---------- Auth (Auth.js / NextAuth v5) ----------
# Generate with: npx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
# Admin login credentials (Credentials provider)
ADMIN_EMAIL="admin@nuul.digital"
ADMIN_PASSWORD="change-me-strong-password"

# ---------- Email (Resend) ----------
RESEND_API_KEY=""
CONTACT_TO_EMAIL="hello@nuul.digital"
CONTACT_FROM_EMAIL="Nuul Digital <noreply@nuul.digital>"

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"   # prod: https://nuul.digital

# ---------- Analytics (optional) ----------
NEXT_PUBLIC_GA_ID=""                  # e.g. G-XXXXXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""       # e.g. nuul.digital

# ---------- AI assistant (optional) ----------
# Set ONE provider to power the site chat with a real LLM. Without a key it
# falls back to a built-in knowledge-based assistant.
ANTHROPIC_API_KEY=""                  # uses Claude
ANTHROPIC_MODEL="claude-3-5-haiku-latest"
OPENAI_API_KEY=""                     # alternative — uses OpenAI
OPENAI_MODEL="gpt-4o-mini"
